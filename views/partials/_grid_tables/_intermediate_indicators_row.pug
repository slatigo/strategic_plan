//- Data Retrieval
- const iEntry = (report.IntermediateEntries || []).find(e => e.spIntermediateOutcomeIndicatorId === iInd.id)
- const iTargetObj = (iInd.Targets || []).find(t => t.fy == reportingFY)

//- Logic: Resolve Custom vs Library and Sanitize
- const isCustom = !iInd.LibraryIndicator
- const displayName = isCustom ? (iInd.adaptedIntermediateIndicator || 'Unnamed Indicator') : (iInd.LibraryIndicator ? iInd.LibraryIndicator.indicator : 'Unnamed')
- const displayCode = (iInd.LibraryIndicator && iInd.LibraryIndicator.indicatorCode && iInd.LibraryIndicator.indicatorCode.toUpperCase() !== 'N/A') ? iInd.LibraryIndicator.indicatorCode : null

//- Unit Resolution (Prioritize effectiveUnit, then National, fallback to null)
- const rawUnit = iInd.effectiveUnit || (iInd.LibraryIndicator && iInd.LibraryIndicator.IntermediateNational ? iInd.LibraryIndicator.IntermediateNational.unit_of_measure : null)
- const displayUnit = (rawUnit && rawUnit.toUpperCase() !== 'N/A') ? rawUnit : null

.row.g-2.mb-2.align-items-center
  .col-md-4
    //- Custom Flag for visual consistency
    if isCustom
      span.badge.bg-warning.text-dark.me-2.x-small CUSTOM
      
    if displayCode
      span.x-small.text-muted.me-1 [#{displayCode}]
      
    span.small.fw-bold #{displayName}
    
  .col-md-1.text-center
    if displayUnit
      span.badge.bg-secondary.x-small #{displayUnit}
    else
      span.x-small.text-muted --
      
  .col-md-2.text-center
    span.badge.bg-light.text-muted.border.x-small 
      | Target: #{ (iTargetObj && iTargetObj.val) ? Number(iTargetObj.val).toLocaleString() : '0' }
      
  .col-md-2
    input.form-control.form-control-sm.text-end.number-separator(
      type="text" 
      name=`intermediates[${iInd.id}][val]` 
      value=(iEntry && iEntry.actualValue != null ? iEntry.actualValue.toLocaleString() : '')
      oninput="formatNumber(this)"
      readonly=isLocked
    )
    input(type="hidden" name=`intermediates[${iInd.id}][id]` value=iInd.id)
    
  .col-md-3
    input.form-control.form-control-sm(
      type="text" 
      name=`intermediates[${iInd.id}][rem]` 
      value=(iEntry && iEntry.remarks ? iEntry.remarks : '') 
      readonly=isLocked
    )