//- This file contains the SHARED structure for MDA (Edit) and NPA (Review)
if plan.SelectedObjectives && plan.SelectedObjectives.length > 0
  each obj in plan.SelectedObjectives
    .card.shadow-sm.mb-5.border-start.border-4.border-primary
      .card-header.bg-white.py-3.border-bottom-0
        .row.align-items-center
          .col
            //- National Context Row
            .d-flex.align-items-center.mb-2
              span.badge.bg-soft-primary.text-primary.border.border-primary.me-2
                i.fas.fa-landmark.me-1
                //- Objective is usually always from Library, but safety first
                | NDP Objective #{obj.LibraryObjective ? obj.LibraryObjective.objectiveCode : 'N/A'}
              small.text-muted.fw-bold.text-uppercase National Standard
            
            //- The National Objective Name (Reference)
            h6.text-muted.mb-2.fw-normal
              | #{obj.LibraryObjective ? obj.LibraryObjective.objectiveName : 'Custom Objective'}
            
            //- The MDA Interpretation (Focus)
            h5.card-title.mb-0.fw-bold.text-dark
              i.fas.fa-arrow-right.me-2.text-primary.small
              | #{obj.orgObjective || (obj.LibraryObjective ? obj.LibraryObjective.objectiveName : 'Untitled')}

          .col-auto
            if !isLocked
              .btn-group
                button.btn.btn-sm.btn-outline-success(
                  type="button"
                  onclick=`prepareOutcomeModal(${obj.id}, ${obj.LibraryObjective ? obj.LibraryObjective.id : 'null'}, ${JSON.stringify(obj.orgObjective || (obj.LibraryObjective ? obj.LibraryObjective.objectiveName : ''))})`
                )
                  i.fas.fa-plus.me-1
                  | Add Outcome
                
                button.btn.btn-sm.btn-outline-danger(
                  type="button"
                  onclick=`removeObjective(${obj.id})`
                )
                  i.fas.fa-trash-alt

      .card-body.p-4
        if obj.SelectedOutcomes && obj.SelectedOutcomes.length > 0
          each oc in obj.SelectedOutcomes
            .outcome-box.mb-5.p-0.bg-white.rounded.border.shadow-sm
              .card-header.bg-light.border-bottom.py-3
                .d-flex.justify-content-between.align-items-center
                  div
                    if oc.LibraryOutcome
                      span.badge.bg-info.text-dark.mb-1 OUTCOME: #{oc.LibraryOutcome.outcomeCode}
                      h6.fw-bold.mb-0= oc.LibraryOutcome.outcomeName
                    else
                      span.badge.bg-secondary.text-white.mb-1 CUSTOM OUTCOME
                      h6.fw-bold.mb-0= oc.adaptedOutcomeIndicator
                  if !isLocked
                    .btn-group
                      button.btn.btn-xs.btn-outline-primary(onclick=`prepareIndicatorModal('Outcome', ${oc.id})`) 
                        i.fas.fa-chart-line.me-1
                        | + Ind
                      button.btn.btn-xs.btn-outline-info(onclick=`prepareIntermediateModal(${oc.id})`) 
                        i.fas.fa-sitemap.me-1
                        | + Int. Outcome
                      button.btn.btn-xs.btn-outline-danger(onclick=`removeOutcome(${oc.id})`)
                        i.fas.fa-trash

              .card-body.position-relative.pb-4
                //- Connection line
                div(style="position:absolute; left:20px; top:0; bottom:0; width:2px; background:#e9ecef; z-index:0;")

                //- 1. OUTCOME INDICATORS
                if oc.SelectedIndicators && oc.SelectedIndicators.length > 0
                  .ms-4.mb-4.position-relative(style="z-index:1")
                    h6.text-uppercase.x-small.fw-bold.text-muted.mb-3 Performance Indicators (Outcome)
                    each ind in oc.SelectedIndicators
                      +indicatorRow(ind, 'Outcome', years, isLocked)

                //- 2. INTERMEDIATE OUTCOMES
                if oc.SelectedIntermediates && oc.SelectedIntermediates.length > 0
                  .ms-4.position-relative(style="z-index:1")
                    h6.text-uppercase.x-small.fw-bold.text-muted.mb-3 Intermediate Outcomes
                    each io in oc.SelectedIntermediates
                      .intermediate-item.ps-3.mb-4.border-start.border-3.border-info
                        .d-flex.justify-content-between.align-items-start
                          div
                            if io.LibraryIntermediate
                              small.text-info.fw-bold.x-small= io.LibraryIntermediate.intermediateOutcomeCode
                              h6.mb-1.small.fw-bold= io.LibraryIntermediate.intermediateOutcome
                            else
                              small.text-secondary.fw-bold.x-small CUSTOM INTERMEDIATE
                              h6.mb-1.small.fw-bold= io.adaptedIntermediateOutcomeIndicator
                          if !isLocked
                            .btn-group
                              button.btn.btn-link.btn-sm.text-info.p-0.me-2(onclick=`prepareIndicatorModal('Intermediate', ${io.id})`) 
                                i.fas.fa-chart-bar
                              button.btn.btn-link.btn-sm.text-success.p-0(onclick=`prepareInterventionModal(${io.id})`) 
                                i.fas.fa-plus-circle
                              button.btn.btn-link.btn-sm.text-danger.p-0.ms-2(onclick=`removeIntermediate(${io.id})`)
                                i.fas.fa-times

                        //- Intermediate Indicators
                        if io.SelectedIndicators && io.SelectedIndicators.length > 0
                          .ms-3.mt-2.mb-3
                            each iInd in io.SelectedIndicators
                              +indicatorRow(iInd, 'Intermediate', years, isLocked)

                        //- 3. INTERVENTIONS & OUTPUTS
                        if io.SelectedInterventions && io.SelectedInterventions.length > 0
                          .ms-3.mt-3
                            each inv in io.SelectedInterventions
                              .intervention-card.p-3.bg-light.border.rounded.mb-3
                                .d-flex.justify-content-between
                                  if inv.LibraryIntervention
                                    h6.small.fw-bold.text-success INTERVENTION: #{inv.LibraryIntervention.interventionCode}
                                  else
                                    h6.small.fw-bold.text-secondary CUSTOM INTERVENTION
                                  if !isLocked
                                    .btn-group
                                      button.btn.btn-xs.btn-outline-success(onclick=`prepareOutputModal(${inv.id})`)
                                        i.fas.fa-plus.me-1
                                        | + Output
                                      button.btn.btn-xs.btn-outline-danger.ms-2(onclick=`removeIntervention(${inv.id})`)
                                        i.fas.fa-trash
                                p.small.mb-2= inv.LibraryIntervention ? inv.LibraryIntervention.intervention : inv.adaptedIntervention
                                
                                //- 4. OUTPUTS
                                if inv.SelectedOutputs && inv.SelectedOutputs.length > 0
                                  .mt-3
                                    each outp in inv.SelectedOutputs
                                      .output-item.p-3.bg-white.border.rounded.mb-3.shadow-sm
                                        .d-flex.justify-content-between.align-items-center.mb-2
                                          h6.small.fw-bold.text-primary.mb-0 
                                            i.fas.fa-caret-right.me-2
                                            if outp.LibraryOutput
                                              | OUTPUT: #{outp.LibraryOutput.output_code || outp.LibraryOutput.outputCode} - #{outp.LibraryOutput.output}
                                            else
                                              | OUTPUT: #{outp.adaptedOutputIndicator}
                                          if !isLocked
                                            .btn-group
                                              button.btn.btn-link.btn-xs.text-primary.p-0(onclick=`prepareIndicatorModal('Output', ${outp.id})`)
                                                i.fas.fa-chart-pie.me-1
                                                | + Ind.
                                              button.btn.btn-link.btn-xs.text-warning.p-0.ms-2(onclick=`prepareActionModal(${outp.id})`)
                                                i.fas.fa-tasks.me-1
                                                | + Action
                                              button.btn.btn-link.btn-xs.text-danger.p-0.ms-2(onclick=`deleteOutput(${outp.id})`)
                                                i.fas.fa-times

                                        //- Output Indicators
                                        if outp.SelectedIndicators && outp.SelectedIndicators.length > 0
                                          .ms-3.mb-3
                                            each opInd in outp.SelectedIndicators
                                              +indicatorRow(opInd, 'Output', years, isLocked)

                                        //- 5. ACTIONS & BUDGET TABLE
                                        if outp.SelectedActions && outp.SelectedActions.length > 0
                                          .table-responsive.mt-2.border.rounded-3.shadow-sm
                                            table.table.align-middle.mb-0
                                              tbody
                                                each act in outp.SelectedActions
                                                  //- ROW 1: ACTION NAME
                                                  tr.bg-light(style="border-top: 2px solid #eee;")
                                                    td.ps-3.pt-3.pb-2(colspan=(years.length))
                                                      .d-flex.align-items-center
                                                        if !act.LibraryAction
                                                          span.badge.rounded-pill.bg-soft-danger.text-danger.border.border-danger.me-2(style="font-size: 0.6rem; padding: 2px 8px;") CUSTOM
                                                        
                                                        h6.mb-0.fw-bold.text-dark(style="font-size: 1rem; line-height: 1.4;")
                                                          if act.LibraryAction
                                                            = act.adaptedOutputAction || act.LibraryAction.action
                                                          else
                                                            = act.adaptedOutputAction
                                                    
                                                    //- Edit/Delete Buttons in the top corner
                                                    if !isLocked
                                                      td.text-end.pt-3.pe-3
                                                        .btn-group
                                                          button.btn.btn-link.btn-sm.text-warning.p-0.me-2(onclick=`prepareActionModal(${outp.id}, ${JSON.stringify(act)})`)
                                                            i.fas.fa-pencil-alt
                                                          button.btn.btn-link.btn-sm.text-danger.p-0(onclick=`deleteAction(${act.id})`)
                                                            i.fas.fa-trash-alt

                                                  //- ROW 2: RESPONSIBLE UNIT (OWN ROW)
                                                  tr
                                                    td.ps-3.py-2(colspan=(years.length + 1))
                                                      .d-flex.align-items-center
                                                        span.text-uppercase.text-muted.fw-bold.me-2(style="font-size: 0.6rem; letter-spacing: 1px;") 
                                                        span.badge.bg-white.text-secondary.border.px-3.py-2.rounded-3.shadow-xs
                                                          i.fas.fa-university.me-2.text-primary.opacity-75
                                                          | #{act.ResponsibleOffice ? act.ResponsibleOffice.name : 'Unassigned Office'}

                                                  //- ROW 3: BUDGET GRID
                                                  tr.border-bottom
                                                    //- Empty space under office name to align budgets to the right
                                                    td.d-none.d-md-table-cell
                                                    
                                                    each y in years
                                                      td.text-end.pe-3.pb-3.pt-2
                                                        - const bVal = act.Budgets ? act.Budgets.find(b => b.fy == y) : null
                                                        .p-2.rounded.bg-gray-50.border-dashed
                                                          .text-muted.fw-bold.mb-1(style="font-size: 0.65rem;") FY #{y}
                                                          .font-monospace.text-dark(class=bVal ? 'fw-bold' : 'opacity-25' style="font-size: 0.9rem;")
                                                            | #{bVal ? Number(bVal.val).toLocaleString() : '0'}
                                        
else
  .alert.alert-warning.text-center.py-5
    i.fas.fa-folder-open.fa-3x.text-muted.mb-3.d-block
    | No content has been added to this Strategic Plan yet.