extends ../layout

block mda_content
  //- Use safe navigation and fallbacks
  - const status = report ? report.status : 'Draft'
  - const isLocked = ['Submitted', 'Approved', 'Under Review'].includes(status)
  
  //- Safe Year Logic
  - const reportingYear = (report && report.Call) ? report.Call.reportingYear : '2025'
  - const baseYear = parseInt(reportingYear) || 2025
  - const nextYearShort = (baseYear + 1).toString().slice(-2)
  - const displayFY = `FY ${baseYear}/${nextYearShort}`
  - const quarter = (report && report.Call) ? report.Call.quarter : 'N/A'

  .container-fluid.py-4
    //- 2. NPA FEEDBACK (Only shows if 'Needs Revision')
    if report.status === 'Needs Revision' && report.Comments && report.Comments.length > 0
      .alert.alert-warning.border-start.border-4.shadow-sm.mb-4
        .d-flex
          i.fas.fa-exclamation-triangle.fa-2x.me-3
          div
            h4.alert-heading Revision Required
            - const latestRemark = report.Comments[report.Comments.length - 1]
            p.mb-0: strong From: #{latestRemark.Author ? latestRemark.Author.name : 'NPA Reviewer'}
            p.fst-italic " #{latestRemark.message} "

    //- 3. HEADER WITH BUTTONS (The part that was missing!)
    .d-flex.justify-content-between.align-items-center.mb-4
      div
        h2.mb-0 
          i.fas.fa-file-signature.me-2.text-primary
          | Quarterly Performance Report
        span.badge.bg-dark #{displayFY} | Quarter: #{report.Call.quarter}
      
      .btn-group.shadow-sm
        if !isLocked
          button.btn.btn-outline-primary#saveDraftBtn(type="submit" form="reportForm")
            i.fas.fa-save.me-2
            | Save Draft
          button.btn.btn-success(type="button" onclick="submitFinalReport()")
            i.fas.fa-paper-plane.me-2
            | Final Submit
        else
          a.btn.btn-outline-secondary(href="/mda/reports")
            i.fas.fa-arrow-left.me-2
            | Back to List

    //- 4. THE FORM & GRID
    form#reportForm(method="POST" action="/mda/reports/save-progress")
      input(type="hidden" name="mdaReportId" value=report.id)
      
      //- This include pulls the actual table logic
      include ../../partials/_report_grid_full

block scripts
  script(src="/js/mda/report-editor.js")