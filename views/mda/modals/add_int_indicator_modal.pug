#intermediateIndicatorModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-lg
    .modal-content
      .modal-header.bg-info.text-white
        h5.modal-title Intermediate Outcome Indicator
        button.btn-close(data-bs-dismiss="modal" aria-label="Close")
      .modal-body
        form#intIndicatorForm
          input#modal_intermediate_parent_id(type="hidden" name="spIntermediateOutcomeId")
          input(type="hidden" name="id")
          
          .mb-3
            label.form-label Select Indicator from Library
            select#intermediate_indicator_select.form-select(name="intermediateOutcomeIndicatorId" required)
              option(value="") -- Select from Library --

          //- ADAPTATION SECTION
          .mb-3
            .form-check.form-switch.mb-2
              input#int_adapt_toggle.form-check-input.adapt-toggle(
                type="checkbox" 
                name="is_adapted" 
                role="switch"
                data-target-container="int_adaptation_container"
              )
              label.form-check-label.fw-bold(for="int_adapt_toggle") Adapt this indicator name?
            
            #int_adaptation_container(style="display: none;")
              label.form-label.text-info.small Customized Intermediate Indicator Name
              textarea#int_adapted_name.form-control(name="adaptedIntermediateOutcomeIndicator" rows="2" placeholder="Modify the name for institutional context...")
              p.text-muted.x-small.mt-1 Customizing this helps link national goals to MUBS-specific operations.

          //- NEW: Row for Office, Baseline, and Data Source
          .row
            .col-md-4.mb-3
              label.form-label Responsible Office
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                if offices && offices.length>0

                  each off in (offices)
                    option(value=off.id)= off.name

            .col-md-4.mb-3
              label.form-label Baseline Value
              input#intermediate_baseline_input.form-control(type="text" name="baselineValue" placeholder="e.g. 15%")
            
            .col-md-4.mb-3
              label.form-label Data Source
              input.form-control(type="text" name="dataSource" placeholder="e.g. Survey, Department Records")

          hr
          h6.mb-3 Annual Targets
          .row.row-cols-5.g-2
            each year in years
              .col
                label.x-small.fw-bold= year
                input.form-control.form-control-sm(type="text" name=`targets[${year}]` placeholder="0")
                
      .modal-footer
        button.btn.btn-secondary(data-bs-dismiss="modal") Cancel
        button.btn.btn-info.text-white(type="submit" form="intIndicatorForm") Save Indicator