#actionModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-lg
    .modal-content
      .modal-header.bg-warning.text-dark
        h5.modal-title Output Action & Budgeting
        button.btn-close(type="button" data-bs-dismiss="modal")
      .modal-body
        form#actionForm
          input(type="hidden" name="id")
          input#modal_action_output_id(type="hidden" name="spOutputId")
          input(type="hidden" name="planId" value=plan.id)
          
          .row
            .col-md-12.mb-3
              label.form-label Select National Action
              select#action_select.form-select(name="outputActionId" required)
                option(value="") -- Select Action --

            .col-md-12.mb-3
              .form-check.form-switch.mb-2
                input#action_adapt_toggle.form-check-input(type="checkbox" name="is_adapted" role="switch")
                label.form-check-label.fw-bold(for="action_adapt_toggle") Adapt this action for MUBS?
              
              #action_adaptation_container(style="display: none;")
                label.form-label.text-dark.small Customized Action Description
                textarea#action_adapted_name.form-control(name="adaptedOutputAction" rows="2" placeholder="Describe the specific MUBS activity...")

            .col-md-6.mb-3
              label.form-label Responsible Office/Unit
              //- CHANGED: From text input to select
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                each off in (offices)
                  option(value=off.id)= off.name

            .col-md-6.mb-3
              label.form-label Primary Funding Source
              select.form-select(name="budgetSourceId" required)
                option(value="") -- Select Source --
                each source in budgetSources
                  //- CHANGED: sourceCode -> code | sourceName -> name
                  option(value=source.id)= `${source.code} - ${source.name}`

          hr
          h6.fw-bold Annual Budget Estimates (UGX)
          .row.row-cols-5.g-2
            each year in years
              .col
                label.x-small.fw-bold= year
                input.form-control.form-control-sm(type="text" name=`budgets[${year}]` placeholder="Amount")

      .modal-footer
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
        button.btn.btn-warning.text-dark(type="submit" form="actionForm") Save Action & Budget