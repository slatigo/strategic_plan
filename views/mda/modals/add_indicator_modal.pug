#outcomeIndicatorModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-xl
    .modal-content
      .modal-header.bg-primary.text-white
        h5.modal-title Link Outcome Indicator & Set Targets
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      .modal-body
        form#outcomeIndicatorForm(action="/mda/plans/indicators/save" method="POST")
          input#modal_outcome_parent_id(type="hidden" name="spOutcomeId")
          input(type="hidden" name="id") 
          
          .row
            .col-md-12.mb-3
              label.form-label Select Indicator from Library
              select#outcome_indicator_select.form-select(name="outcomeIndicatorId" required)
                option(value="") -- Select --
            
            //- ADAPTATION SECTION
            .col-md-12.mb-3
                .form-check.form-switch.mb-2
                  input#outcome_adapt_toggle.form-check-input.adapt-toggle(
                    type="checkbox" 
                    name="is_adapted" 
                    role="switch" 
                    data-target-container="outcome_adaptation_container"
                  )
                  label.form-check-label.fw-bold(for="outcome_adapt_toggle") Adapt this indicator name?
                
                #outcome_adaptation_container(style="display: none;")
                  label.form-label.text-primary.small Customized Outcome Indicator Name
                  textarea#outcome_adapted_name.form-control(name="adaptedOutcomeIndicator" rows="2" placeholder="Modify the indicator name...")

            //- NEW: Responsibility & Data Source Row
            .col-md-4.mb-3
              label.form-label Responsible Office/Unit
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                each off in (offices)
                  option(value=off.id)= off.name

            .col-md-4.mb-3
              label.form-label Baseline Value
              input#outcome_baseline_input.form-control(type="text" name="baselineValue" placeholder="e.g. 10%")
            
            .col-md-4.mb-3
              label.form-label Data Source / Means of Verification
              input.form-control(type="text" name="dataSource" placeholder="e.g. Annual Report, EMIS, HRIS")
          
          hr
          h6.fw-bold Annual Targets
          .row
            each year in years || [2025, 2026, 2027, 2028, 2029]
              .col
                label.small.form-label= year
                input.form-control.form-control-sm(type="text" name=`targets[${year}]` placeholder="Target")
                
      .modal-footer
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
        button.btn.btn-primary(type="submit" form="outcomeIndicatorForm") Save Indicator