#outputIndicatorModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-xl
    .modal-content
      .modal-header.bg-success.text-white
        h5.modal-title Output Indicator & Targets
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      .modal-body
        form#outputIndicatorForm(action="/api/plan/save-output-indicator" method="POST")
          input(type="hidden" name="id")
          input#modal_output_parent_id(type="hidden" name="spOutputId")
          input(type="hidden" name="planId" value=plan.id)
          
          .row
            .col-md-12.mb-3
              label.form-label Select Output Indicator from Library
              select#output_indicator_select.form-select(name="outputIndicatorId" required)
                option(value="") -- Select --
            
            //- THE ADAPTATION SECTION
            .col-md-12.mb-3
              .form-check.form-switch.mb-2
                input#output_adapt_toggle.form-check-input.adapt-toggle(
                  type="checkbox" 
                  name="is_adapted" 
                  role="switch"
                  data-target-container="output_adaptation_container"
                )
                label.form-check-label.fw-bold(for="output_adapt_toggle") Adapt this indicator name?
              
              #output_adaptation_container(style="display: none;")
                label.form-label.text-success.small Customized Indicator Name
                textarea#output_adapted_name.form-control(name="adaptedOutputIndicator" rows="2" placeholder="Modify the indicator name...")
                p.text-muted.x-small.mt-1 This customized name will appear on your internal reports.

            //- NEW: Row for Office, Baseline, and Data Source
            .col-md-4.mb-3
              label.form-label Responsible Office
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                if offices && offices.length
                  each off in (offices)
                    option(value=off.id)= off.name

            .col-md-4.mb-3
              label.form-label Baseline Value
              input.form-control(type="text" name="baselineValue" placeholder="e.g. 0")
            
            .col-md-4.mb-3
              label.form-label Data Source / Means of Verification
              input.form-control(type="text" name="dataSource" placeholder="e.g. Activity Report, Attendance List")
          
          hr
          h6.fw-bold Annual Targets
          .row
            each year in years || [2025, 2026, 2027, 2028, 2029]
              .col
                label.small.form-label= year
                input.form-control.form-control-sm(type="text" name=`targets[${year}]` placeholder="Target")
                
      .modal-footer
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
        button.btn.btn-success(type="submit" form="outputIndicatorForm") Save Output Indicator