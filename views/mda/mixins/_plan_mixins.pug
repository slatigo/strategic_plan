//- views/mda/mixins/_plan_mixins.pug

mixin indicatorRow(item, level, years)
  .indicator-item.bg-white.p-2.border.rounded.mb-2.shadow-none
    .row.align-items-center
      .col-md-5
        .d-flex.justify-content-between.align-items-start
          div
            //- 1. Dynamically resolve the library link
            - let lib = item.LibraryIndicator || item.LibraryIntermediateIndicator || item.LibraryOutputIndicator
            
            //- 2. Resolve Adaptation Key (Handling 'Intermediate' edge case)
            - const adaptedKey = level === 'Intermediate' ? 'adaptedIntermediateOutcomeIndicator' : `adapted${level}Indicator`
            - let adaptedText = item[adaptedKey]
            
            //- 3. Display Code & Source Badge
            .mb-1
              span.badge.bg-secondary.x-small.me-1= lib ? (lib.indicatorCode || lib.intermediate_outcome_indicator_code || lib.output_indicator_code || lib.indicator_code) : 'N/A'
              if item.dataSource
                span.text-muted.x-small(title="Data Source")
                  i.fas.fa-database.ms-1.me-1
                  | #{item.dataSource}
            
            //- 4. Display Text (Adapted vs Library)
            if adaptedText && adaptedText !== '0' && adaptedText !== ''
              p.mb-0.x-small.text-wrap.text-primary.fw-bold
                i.fas.fa-pen-nib.me-1.small
                | #{adaptedText}
            else
              p.mb-0.x-small.text-wrap= lib ? (lib.indicator || lib.indicatorName || lib.intermediate_outcome_indicator || lib.output_indicator) : 'N/A'
            
            //- 5. NEW: Responsible Office Display
            if item.ResponsibleOffice
              .mt-1
                span.text-info.x-small.fw-bold
                  i.fas.fa-building.me-1
                  | #{item.ResponsibleOffice.name}
          
          .btn-group.ms-2
            button.btn.btn-link.btn-xs.text-primary.p-0(onclick=`editIndicator('${level}', ${item.id})` title="Edit")
              i.fas.fa-edit
            button.btn.btn-link.btn-xs.text-danger.p-0.ms-2(onclick=`removeIndicator('${level}', ${item.id})` title="Delete")
              i.fas.fa-trash-alt
              
      .col-md-7
        .row.g-0.text-center
          .col.border-end
            small.d-block.text-muted.x-small Base
            span.badge.bg-light.text-dark.border.x-small= item.baselineValue || '0'
          each year in years
            - let target = item.Targets ? item.Targets.find(t => t.fy == year) : null
            .col
              small.d-block.text-muted.x-small #{year}
              span.fw-bold.x-small= target ? target.val : '-'