extends ../layout

block mda_content
  - let isLocked = plan.status !== 'Draft' && plan.status !== 'Pending Correction'
  - let isPrintMode = false

  link(href="/stylesheets/plan-editor.css" rel="stylesheet")
  include ./mixins/_plan_mixins.pug
  
  input#global_plan_id(type="hidden" value=plan.id)

  .container-fluid.py-4
    //- Header Section
    .d-flex.justify-content-between.align-items-center.mb-4.no-print
      div
        h2.mb-0 
          if isLocked
            i.fas.fa-lock.me-2.text-muted
            | Strategic Plan (View Mode)
          else
            i.fas.fa-edit.me-2.text-primary
            | Strategic Plan Editor
        p.text-muted Programme: #{plan.Programme ? plan.Programme.programmeName : 'Not Assigned'}
      
      .btn-group
        a.btn.btn-outline-primary(href=`/mda/plans/view/${plan.id}?print=true` target="_blank")
          i.fas.fa-file-pdf.me-2
          | Generate Report
        if !isLocked
          button.btn.btn-primary.ms-2(data-bs-toggle="modal" data-bs-target="#addObjectiveModal") 
            i.fas.fa-plus.me-2
            | Add Objective

    .row
      //- Column 1: Now forced to col-lg-12 to fill all available space
      .col-lg-12
        include ../../partials/_plan_readonly_core.pug

        //- MDA Footer (Submission Logic)
        hr.my-5
        if !isLocked
          .submission-section.bg-light.p-5.rounded.border.text-center.mb-5.shadow-sm
            i.fas.fa-paper-plane.fa-3x.text-primary.mb-3
            h4 Ready to Finalize?
            p.text-muted 
              | Submitting this Strategic Plan will notify the 
              strong National Planning Authority (NPA) 
              | for review.
            .d-flex.justify-content-center.gap-3.mt-4
              button.btn.btn-primary.btn-lg.px-5(type="button" onclick=`submitToNPA(${plan.id})`)
                | Submit to NPA for Review
        else
          .text-center.mb-5
            .alert.alert-info.d-inline-block.px-5
              i.fas.fa-info-circle.me-2
              | This plan is currently **#{plan.status}** and is locked.

  //- FEEDBACK SYSTEM (Offcanvas Drawer + Floating Button)
  if plan.Comments && plan.Comments.length > 0
    //- Floating Action Button (Bottom Right)
    button.btn.btn-info.text-white.shadow-lg.no-print(
      type="button" 
      data-bs-toggle="offcanvas" 
      data-bs-target="#feedbackDrawer"
      style="position: fixed; bottom: 30px; right: 30px; z-index: 1060; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"
      title="View Feedback"
    )
      i.fas.fa-comment-dots.fa-lg
      span.position-absolute.top-0.start-100.translate-middle.badge.rounded-pill.bg-danger(style="font-size: 0.7rem;")
        | #{plan.Comments.length}

    //- The Drawer itself
    .offcanvas.offcanvas-end#feedbackDrawer(tabindex="-1" aria-labelledby="feedbackDrawerLabel" style="width: 450px;")
      .offcanvas-header.bg-info.text-white.shadow-sm
        h5#feedbackDrawerLabel.mb-0 
          i.fas.fa-history.me-2
          | NPA Feedback History
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="offcanvas" aria-label="Close")
      .offcanvas-body.bg-light.p-4
        each comment in plan.Comments
          .card.mb-3.border-0.shadow-sm
            .card-body.p-3
              .d-flex.justify-content-between.align-items-center.mb-2
                div
                  i.fas.fa-user-circle.me-1(class=comment.isAdminComment ? 'text-primary' : 'text-success')
                  small.fw-bold(class=comment.isAdminComment ? 'text-primary' : 'text-success')
                    | #{comment.Author ? comment.Author.name : 'System'}
                small.text-muted(style="font-size: 0.7rem;") #{new Date(comment.createdAt).toLocaleDateString()}
              
              p.small.mb-2.text-dark.lh-base= comment.message
              
              if comment.statusAtTime
                .text-end
                  span.badge.rounded-pill(style="font-size: 0.65rem;" class=comment.statusAtTime === 'Approved' ? 'bg-success' : 'bg-warning text-dark')
                    i.fas.fa-tag.me-1
                    | #{comment.statusAtTime}

  //- MODALS
  if !isLocked
    include ./modals/add_objective_modal.pug
    include ./modals/add_outcome_modal.pug
    include ./modals/add_intermediate_modal.pug
    include ./modals/add_indicator_modal.pug
    include ./modals/add_int_indicator_modal.pug
    include ./modals/add_intervention_modal.pug
    include ./modals/add_output_modal.pug
    include ./modals/add_output_indicator_modal.pug
    include ./modals/add_output_action_modal.pug

block scripts
  script.
    window.planId = "#{plan.id}";
  script(src="/js/mda/plan-editor.js")