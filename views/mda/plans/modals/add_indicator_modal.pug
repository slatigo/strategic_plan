#outcomeIndicatorModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-xl
    .modal-content
      .modal-header.bg-primary.text-white
        h5.modal-title 
          i.fas.fa-link.me-2
          | Set Indicator & Targets
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      .modal-body
        form#outcomeIndicatorForm
          input#modal_outcome_parent_id(type="hidden" name="spOutcomeId")
          input(type="hidden" name="id") 
          
          .row
            .col-md-12.mb-3
              .d-flex.justify-content-between.align-items-center.mb-2
                label.form-label.fw-bold Objective Indicator
                .form-check.form-switch
                  input#outcome_custom_toggle.form-check-input(type="checkbox" name="is_custom" role="switch")
                  label.form-check-label.small.text-danger.fw-bold(for="outcome_custom_toggle") Not in Library? (Custom)

              //- 1. Library Selection Mode
              #outcome_library_container
                .input-group
                  select#outcome_indicator_select.form-select(name="outcomeIndicatorId" required)
                    option(value="") -- Select from Library --
                  span#outcome_unit_badge.input-group-text.bg-light.text-muted.small.unit-label Unit: ---
                
                .form-check.form-switch.mt-2.mb-2
                  input#outcome_adapt_toggle.form-check-input.adapt-toggle(type="checkbox" name="is_adapted" role="switch" data-target-container="outcome_adaptation_container")
                  label.form-check-label.small(for="outcome_adapt_toggle") Adapt this library name?
                #outcome_adaptation_container(style="display: none;")
                  textarea#outcome_adapted_name.form-control(name="adaptedOutcomeIndicator" rows="2" placeholder="Modify the indicator name for your institution...")

              //- 2. Custom Input Mode
              #outcome_custom_container(style="display: none;")
                .row.g-2
                  .col-md-8
                    label.x-small.text-muted Custom Indicator Name
                    input#outcome_custom_name.form-control(type="text" name="customIndicatorName" placeholder="Enter custom indicator name...")
                  .col-md-4
                    label.x-small.text-muted Unit of Measure
                    select#outcome_custom_unit.form-select(name="customUnit")
                      option(value="") -- Select Unit --
                      each uVal in (unitOfMeasures || [])
                        option(value=uVal) #{uVal}

            .col-md-4.mb-3
              label.form-label.fw-bold Responsible Office
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                each dept in (offices || [])
                  option(value=dept.id) #{dept.name}

            .col-md-4.mb-3
              label.form-label.fw-bold Baseline Value
              .input-group
                input#outcome_baseline_input.form-control(type="text" name="baselineValue" placeholder="0.00")
                span.input-group-text.bg-light.small.unit-label ---
            
            .col-md-4.mb-3
              label.form-label.fw-bold Data Source
              input.form-control(type="text" name="dataSource" placeholder="e.g. Annual Report")
          
          hr
          
          .d-flex.justify-content-between.align-items-center.mb-3
            h6.fw-bold.mb-0 
              i.fas.fa-bullseye.me-2.text-danger
              | Annual Targets
            span.badge.bg-light.text-primary.border.px-3.small
              i.fas.fa-info-circle.me-1
              | Blue values = NDP Benchmarks (Library Only)

          #national_reference_row.row.bg-light.rounded.p-3.mb-3.border.mx-0.g-2
            if years && years.length > 0
              each yr in years
                .col.text-center
                  label.x-small.text-uppercase.text-muted.d-block NDP #{yr}
                  div.fw-bold.small.text-primary.nat-val(id=`nat_val_${yr}`) --
            else
              .col-12.text-center.text-muted.small No planning years found.

          .row.g-2
            if years && years.length > 0
              each yr in years
                .col
                  label.small.form-label.fw-bold #{yr}
                  .input-group.input-group-sm
                    input.form-control(type="text" name=`targets[${yr}]` placeholder="0.00")
                    span.input-group-text.bg-light.x-small.unit-label ---
                
      .modal-footer.bg-light
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
        button.btn.btn-primary.px-4(type="submit" form="outcomeIndicatorForm") 
          i.fas.fa-save.me-2  
          | Save Indicator