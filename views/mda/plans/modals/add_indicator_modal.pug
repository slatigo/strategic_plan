#outcomeIndicatorModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-xl
    .modal-content
      .modal-header.bg-primary.text-white
        h5.modal-title 
          i.fas.fa-link.me-2
          | Link Outcome Indicator & Set Targets
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      .modal-body
        form#outcomeIndicatorForm(action="/mda/plans/indicators/save" method="POST")
          input#modal_outcome_parent_id(type="hidden" name="spOutcomeId")
          input(type="hidden" name="id") 
          
          .row
            .col-md-12.mb-3
              label.form-label.fw-bold Select Indicator from Library
              .input-group
                select#outcome_indicator_select.form-select(name="outcomeIndicatorId" required)
                  option(value="") -- Select --
                span#outcome_unit_badge.input-group-text.bg-light.text-muted.small Unit: ---
            
            .col-md-12.mb-3
              .form-check.form-switch.mb-2
                input#outcome_adapt_toggle.form-check-input.adapt-toggle(type="checkbox" name="is_adapted" role="switch" data-target-container="outcome_adaptation_container")
                label.form-check-label.fw-bold(for="outcome_adapt_toggle") Adapt this indicator name?
              #outcome_adaptation_container(style="display: none;")
                textarea#outcome_adapted_name.form-control(name="adaptedOutcomeIndicator" rows="2" placeholder="Modify the indicator name...")

            .col-md-4.mb-3
              label.form-label.fw-bold Responsible Office/Unit
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                - if (offices && offices.length > 0)
                  - for (var i = 0; i < offices.length; i++)
                    option(value=offices[i].id) #{offices[i].name}

            .col-md-4.mb-3
              label.form-label.fw-bold Baseline Value
              .input-group
                input#outcome_baseline_input.form-control(type="text" name="baselineValue" placeholder="Wait for selection...")
                span.input-group-text.unit-append.bg-light.small ---
            
            .col-md-4.mb-3
              label.form-label.fw-bold Data Source
              input.form-control(type="text" name="dataSource" placeholder="e.g. Annual Report")
          
          hr
          
          .d-flex.justify-content-between.align-items-center.mb-3
            h6.fw-bold.mb-0 
              i.fas.fa-bullseye.me-2.text-danger
              | Annual Targets
            span.badge.bg-light.text-primary.border.px-3.small
              i.fas.fa-info-circle.me-1
              | Blue values are National Development Plan (NDP) Benchmarks

          //- 1. NATIONAL REFERENCE ROW
          .row.bg-light.rounded.p-3.mb-3.border.mx-0.g-2
            //- We put the array directly in the loop to avoid the "with expression" error
            - for (var k = 2025; k <= 2029; k++)
              .col.text-center
                label.x-small.text-uppercase.text-muted.d-block NDP #{k}
                div.fw-bold.small.text-primary(id=`nat_val_${k}`) --
          
          //- 2. MDA INPUT ROW
          .row.g-2
            - for (var l = 2025; l <= 2029; l++)
              .col
                label.small.form-label.fw-bold #{l}
                .input-group.input-group-sm
                  input.form-control(type="text" name=`targets[${l}]` placeholder="0.00")
                  span.input-group-text.unit-append.x-small ---
                
      .modal-footer.bg-light
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
        button.btn.btn-primary.px-4(type="submit" form="outcomeIndicatorForm") 
          i.fas.fa-save.me-2
          | Save Indicator