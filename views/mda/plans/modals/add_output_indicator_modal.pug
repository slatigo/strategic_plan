#outputIndicatorModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-xl
    .modal-content
      .modal-header.bg-success.text-white
        h5.modal-title 
          i.fas.fa-check-double.me-2
          | Link Output Indicator & Set Targets
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      .modal-body
        form#outputIndicatorForm(action="/mda/plans/indicators/save" method="POST")
          input#modal_output_parent_id(type="hidden" name="spOutputId")
          input(type="hidden" name="id") 
          //- Useful if your backend needs the plan reference
          input(type="hidden" name="planId" value=(plan ? plan.id : '')) 
          
          .row
            .col-md-12.mb-3
              label.form-label.fw-bold Select Output Indicator from Library
              .input-group
                select#output_indicator_select.form-select(name="outputIndicatorId" required)
                  option(value="") -- Select --
                //- ID specifically for Output level
                span#out_unit_badge.input-group-text.bg-light.text-muted.small Unit: ---
            
            .col-md-12.mb-3
              .form-check.form-switch.mb-2
                input#output_adapt_toggle.form-check-input.adapt-toggle(type="checkbox" name="is_adapted" role="switch" data-target-container="output_adaptation_container")
                label.form-check-label.fw-bold(for="output_adapt_toggle") Adapt this indicator name?
              #output_adaptation_container(style="display: none;")
                label.form-label.text-success.small Customized Output Indicator Name
                textarea#output_adapted_name.form-control(name="adaptedOutputIndicator" rows="2" placeholder="Modify the indicator name for MUBS context...")

            .col-md-4.mb-3
              label.form-label.fw-bold Responsible Office
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                //- NATIVE JS LOOP to avoid "valid identifier" errors
                - if (offices && offices.length > 0)
                  - for (var i = 0; i < offices.length; i++)
                    option(value=offices[i].id) #{offices[i].name}

            .col-md-4.mb-3
              label.form-label.fw-bold Baseline Value
              .input-group
                input#output_baseline_input.form-control(type="text" name="baselineValue" placeholder="Wait for selection...")
                span.input-group-text.unit-append.bg-light.small ---
            
            .col-md-4.mb-3
              label.form-label.fw-bold Data Source / Means of Verification
              input.form-control(type="text" name="dataSource" placeholder="e.g. Activity Report, Attendance List")
          
          hr
          
          .d-flex.justify-content-between.align-items-center.mb-3
            h6.fw-bold.mb-0 
              i.fas.fa-bullseye.me-2.text-success
              | Annual Targets (Output)
            span.badge.bg-light.text-success.border.px-3.small
              i.fas.fa-info-circle.me-1
              | Blue values are National Development Plan (NDP) Benchmarks

          //- 1. NATIONAL REFERENCE ROW (NDP Targets)
          .row.bg-light.rounded.p-3.mb-3.border.mx-0.g-2
            //- Direct loop to avoid the "years is not defined" error
            - for (var k = 2025; k <= 2029; k++)
              .col.text-center
                label.x-small.text-uppercase.text-muted.d-block NDP #{k}
                //- JS targets 'out_nat_val_' IDs
                div.fw-bold.small.text-success(id=`out_nat_val_${k}`) --
          
          //- 2. MDA INPUT ROW (Target entry fields)
          .row.g-2
            - for (var l = 2025; l <= 2029; l++)
              .col
                label.small.form-label.fw-bold #{l}
                .input-group.input-group-sm
                  input.form-control(type="text" name=`targets[${l}]` placeholder="0.00")
                  span.input-group-text.unit-append.x-small ---
                
      .modal-footer.bg-light
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
        button.btn.btn-success.px-4(type="submit" form="outputIndicatorForm") 
          i.fas.fa-save.me-2
          | Save Output Indicator