#outputIndicatorModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-xl
    .modal-content
      .modal-header.bg-success.text-white
        h5.modal-title 
          i.fas.fa-check-double.me-2
          | Link Output Indicator & Set Targets
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      .modal-body
        form#outputIndicatorForm
          input#modal_output_parent_id(type="hidden" name="spOutputId")
          input(type="hidden" name="id") 
          input(type="hidden" name="planId" value=(plan ? plan.id : '')) 
          
          .row
            .col-md-12.mb-3
              .d-flex.justify-content-between.align-items-center.mb-2
                label.form-label.fw-bold Output Indicator
                .form-check.form-switch
                  input#output_custom_toggle.form-check-input(type="checkbox" name="is_custom" role="switch")
                  label.form-check-label.small.text-danger.fw-bold(for="output_custom_toggle") Not in Library? (Custom)

              //- 1. Library Selection Mode
              #output_library_container
                .input-group
                  select#output_indicator_select.form-select(name="outputIndicatorId" required)
                    option(value="") -- Select from Library --
                    //- Populate library options if they exist
                    if libraryOutputIndicators
                      each lib in libraryOutputIndicators
                        option(value=lib.id) #{lib.name}
                  span#out_unit_badge.input-group-text.bg-light.text-muted.small Unit: ---
                
                .form-check.form-switch.mt-2.mb-2
                  input#output_adapt_toggle.form-check-input.adapt-toggle(type="checkbox" name="is_adapted" role="switch" data-target-container="output_adaptation_container")
                  label.form-check-label.small(for="output_adapt_toggle") Adapt this library name?
                #output_adaptation_container(style="display: none;")
                  textarea#output_adapted_name.form-control(name="adaptedOutputIndicator" rows="2" placeholder="Modify the indicator name for institutional context...")

              //- 2. Custom Input Mode
              #output_custom_container(style="display: none;")
                .row.g-2
                  .col-md-8
                    label.x-small.text-muted Custom Output Indicator Name
                    input#output_custom_name.form-control(type="text" name="customIndicatorName" placeholder="Enter custom indicator name...")
                  .col-md-4
                    label.x-small.text-muted Unit of Measure
                    select#output_custom_unit.form-select(name="customUnit")
                      option(value="") -- Select Unit --
                      each uVal in (unitOfMeasures || [])
                        option(value=uVal) #{uVal}

            .col-md-4.mb-3
              label.form-label.fw-bold Responsible Office
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                each dept in (offices || [])
                  option(value=dept.id) #{dept.name}

            .col-md-4.mb-3
              label.form-label.fw-bold Baseline Value
              .input-group
                input#output_baseline_input.form-control(type="text" name="baselineValue" placeholder="0.00")
                span.input-group-text.unit-append.bg-light.small ---
            
            .col-md-4.mb-3
              label.form-label.fw-bold Data Source / Means of Verification
              input.form-control(type="text" name="dataSource" placeholder="e.g. Activity Report, Attendance List")
          
          hr
          
          .d-flex.justify-content-between.align-items-center.mb-3
            h6.fw-bold.mb-0 
              i.fas.fa-bullseye.me-2.text-success
              | Annual Targets (Output)
            span.badge.bg-light.text-success.border.px-3.small
              i.fas.fa-info-circle.me-1
              | Blue values = NDP Benchmarks

          //- National Reference Row (Dynamic Years)
          .row.bg-light.rounded.p-3.mb-3.border.mx-0.g-2
            if years && years.length > 0
              each yr in years
                .col.text-center
                  label.x-small.text-uppercase.text-muted.d-block NDP #{yr}
                  div.fw-bold.small.text-success(id=`out_nat_val_${yr}`) --
            else
              .col-12.text-center.text-muted.small No years defined.

          //- MDA Input Row (Dynamic Years)
          .row.g-2
            if years && years.length > 0
              each yr in years
                .col
                  label.small.form-label.fw-bold #{yr}
                  .input-group.input-group-sm
                    input.form-control(type="text" name=`targets[${yr}]` placeholder="0.00")
                    span.input-group-text.unit-append.x-small ---
                
      .modal-footer.bg-light
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
        button.btn.btn-success.px-4(type="submit" form="outputIndicatorForm") 
          i.fas.fa-save.me-2  
          | Save Output Indicator