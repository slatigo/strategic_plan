#intermediateIndicatorModal.modal.fade(tabindex="-1" aria-hidden="true")
  .modal-dialog.modal-xl
    .modal-content
      .modal-header.bg-info.text-white
        h5.modal-title 
          i.fas.fa-layer-group.me-2
          | Link Intermediate Indicator & Set Targets
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      .modal-body
        form#intIndicatorForm
          input#modal_intermediate_parent_id(type="hidden" name="spIntermediateOutcomeId")
          input(type="hidden" name="id") 
          
          .row
            .col-md-12.mb-3
              .d-flex.justify-content-between.align-items-center.mb-2
                label.form-label.fw-bold Intermediate Indicator
                .form-check.form-switch
                  input#int_custom_toggle.form-check-input(type="checkbox" name="is_custom" role="switch")
                  label.form-check-label.small.text-danger.fw-bold(for="int_custom_toggle") Not in Library? (Custom)

              //- 1. Library Selection Mode
              #int_library_container
                .input-group
                  select#intermediate_indicator_select.form-select(name="intermediateOutcomeIndicatorId" required)
                    option(value="") -- Select from Library --
                  span#int_unit_badge.input-group-text.bg-light.text-muted.small.unit-label Unit: ---
                
                .form-check.form-switch.mt-2.mb-2
                  input#int_adapt_toggle.form-check-input.adapt-toggle(type="checkbox" name="is_adapted" role="switch" data-target-container="int_adaptation_container")
                  label.form-check-label.small(for="int_adapt_toggle") Adapt this library name?
                #int_adaptation_container(style="display: none;")
                  textarea#int_adapted_name.form-control(name="adaptedIntermediateOutcomeIndicator" rows="2" placeholder="Modify name for institutional context...")

              //- 2. Custom Input Mode
              #int_custom_container(style="display: none;")
                .row.g-2
                  .col-md-8
                    label.x-small.text-muted Custom Intermediate Indicator Name
                    input#int_custom_name.form-control(type="text" name="customIndicatorName" placeholder="Enter custom indicator name...")
                  .col-md-4
                    label.x-small.text-muted Unit of Measure
                    select#int_custom_unit.form-select(name="customUnit")
                      option(value="") -- Select Unit --
                      each uVal in (unitOfMeasures || [])
                        option(value=uVal) #{uVal}

            .col-md-4.mb-3
              label.form-label.fw-bold Responsible Office
              select.form-select(name="responsibleOfficeId" required)
                option(value="") -- Select Office --
                each dept in (offices || [])
                  option(value=dept.id) #{dept.name}

            .col-md-4.mb-3
              label.form-label.fw-bold Baseline Value
              .input-group
                input#intermediate_baseline_input.form-control(type="text" name="baselineValue" placeholder="0.00")
                span.input-group-text.bg-light.small.unit-label ---
            
            .col-md-4.mb-3
              label.form-label.fw-bold Data Source
              input.form-control(type="text" name="dataSource" placeholder="e.g. Survey, Department Records")
          
          hr
          
          h6.fw-bold.mb-3 Annual Targets (Intermediate)
          .row.g-2
            if years && years.length > 0
              each yr in years
                .col
                  label.small.form-label.fw-bold #{yr}
                  .input-group.input-group-sm
                    input.form-control(type="text" name=`targets[${yr}]` placeholder="0.00")
                    span.input-group-text.x-small.unit-label ---
            else
              .col-12
                p.text-danger.small No planning years defined.
                
      .modal-footer.bg-light
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
        button.btn.btn-info.text-white.px-4(type="submit" form="intIndicatorForm") 
          i.fas.fa-save.me-2  
          | Save Indicator