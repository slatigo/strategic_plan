doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title} | MDA Planning Portal
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet")
    style.
      :root { --mda-primary: #2c3e50; --mda-accent: #3498db; }
      body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; overflow-x: hidden; }
      
      #wrapper { display: flex; width: 100%; }

      /* THE FIX: Sticky Sidebar */
      #sidebar-wrapper { 
        min-width: 250px; 
        max-width: 250px; 
        height: 100vh; 
        background: var(--mda-primary); 
        position: sticky; 
        top: 0; 
        display: flex;
        flex-direction: column;
        z-index: 1000;
      }

      .sidebar-heading { padding: 2rem 1.5rem; color: #fff; font-weight: 800; border-bottom: 1px solid rgba(255,255,255,0.1); }
      .nav-link { color: rgba(255,255,255,0.7); padding: 1rem 1.5rem; border-left: 4px solid transparent; }
      .nav-link:hover { color: #fff; background: rgba(255,255,255,0.05); }
      .nav-link.active { color: #fff; background: rgba(255,255,255,0.1); border-left-color: var(--mda-accent); }
      
      /* Allows sidebar nav to scroll if there are too many links */
      .sidebar-nav-container { overflow-y: auto; flex-grow: 1; }

      #page-content-wrapper { width: 100%; min-width: 0; }
      .navbar-mda { background: #fff; border-bottom: 1px solid #e3e6f0; padding: 0.75rem 1.5rem; }

  body
    #wrapper
      #sidebar-wrapper
        .sidebar-heading 
          i.fas.fa-chart-line.me-2
          | PLANNER PORTAL
        
        .sidebar-nav-container
          .nav.flex-column.mt-3
            a.nav-link(href="/mda/dashboard" class=activePage === 'dashboard' ? 'active' : '')
              i.fas.fa-home.me-3
              | Dashboard
            
            a.nav-link(href="/mda/plans" class=(activePage === 'plans' ? 'active' : ''))
                i.fas.fa-file-signature.me-3
                | Strategic Plans
            
            a.nav-link(href="/mda/reports" class=activePage === 'reports' ? 'active' : '')
              i.fas.fa-tasks.me-3
              | Progress Reports

            hr.mx-3.text-white-50
            
            .sidebar-heading.pt-0.pb-2.small.text-uppercase.text-white-50 Configuration
            
            a.nav-link(href="/mda/settings" class=(activePage === 'settings' || activePage === 'offices' || activePage === 'budgetSources') ? 'active' : '')
              i.fas.fa-gears.me-3
              | MDA Settings

        //- Logout at the very bottom
        .mt-auto.border-top.border-secondary
          a.nav-link.text-danger(href="/logout")
            i.fas.fa-power-off.me-3
            | Logout

      #page-content-wrapper
        header.navbar.bg-white.shadow-sm.sticky-top
          .container-fluid.px-4
            h5.mb-0.fw-bold.text-dark= title
            
            //- Wrap the user menu in a div to ensure proper flex alignment
            .d-flex.align-items-center
              include ../partials/_user_menu

        .container-fluid
          block mda_content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")
    block scripts