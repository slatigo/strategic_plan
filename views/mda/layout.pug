doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title} | MDA Planning Portal
    //- Bootstrap 5 & FontAwesome
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet")
    style.
      :root { --mda-primary: #2c3e50; --mda-accent: #3498db; }
      body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; }
      #wrapper { display: flex; width: 100%; align-items: stretch; }
      #sidebar-wrapper { min-height: 100vh; width: 250px; background: var(--mda-primary); transition: all 0.3s; }
      .sidebar-heading { padding: 2rem 1.5rem; color: #fff; font-weight: 800; border-bottom: 1px solid rgba(255,255,255,0.1); }
      .nav-link { color: rgba(255,255,255,0.7); padding: 1rem 1.5rem; border-left: 4px solid transparent; }
      .nav-link:hover { color: #fff; background: rgba(255,255,255,0.05); }
      .nav-link.active { color: #fff; background: rgba(255,255,255,0.1); border-left-color: var(--mda-accent); }
      #page-content-wrapper { width: 100%; padding: 20px; }
      .navbar-mda { background: #fff; border-bottom: 1px solid #e3e6f0; padding: 0.75rem 1.5rem; }

  body
    #wrapper
      //- Sidebar
      #sidebar-wrapper
        .sidebar-heading 
          i.fas.fa-chart-line.me-2
          | PLANNER PORTAL
        .nav.flex-column.mt-3
          a.nav-link(href="/mda/dashboard" class=activePage === 'dashboard' ? 'active' : '')
            i.fas.fa-home.me-3
            | Dashboard
          
          a.nav-link(href="/mda/plans" class=activePage === 'plans' ? 'active' : '')
            i.fas.fa-file-signature.me-3
            | Strategic Plans
          
          a.nav-link(href="/mda/reports" class=activePage === 'reports' ? 'active' : '')
            i.fas.fa-tasks.me-3
            | Progress Reports

          hr.mx-3.text-white-50
          
          hr.mx-3.text-white-50
          
          .sidebar-heading.pt-0.pb-2.small.text-uppercase.text-white-50 Configuration
          
          //- Unified Settings Link
          a.nav-link(href="/mda/settings" class=(activePage === 'settings' || activePage === 'offices' || activePage === 'budgetSources') ? 'active' : '')
            i.fas.fa-gears.me-3
            | MDA Settings

          a.nav-link.text-danger.mt-auto(href="/logout")
            i.fas.fa-power-off.me-3
            | Logout

      //- Page Content
      #page-content-wrapper
        //- Top Navigation
        nav.navbar.navbar-expand.navbar-mda.mb-4.rounded.shadow-sm
          .container-fluid
            span.navbar-text.fw-bold.text-dark
              i.fas.fa-building.me-2
              | #{user.mdaName  ? user.mdaName : 'Unknown MDA'}
            
            ul.navbar-nav.ms-auto
              li.nav-item.dropdown
                a.nav-link.dropdown-toggle.text-dark(href="#" data-bs-toggle="dropdown")
                  i.fas.fa-user-circle.me-2
                  | #{user.name}
                ul.dropdown-menu.dropdown-menu-end
                  li: a.dropdown-item(href="/profile") Profile
                  li: hr.dropdown-divider
                  li: a.dropdown-item.text-danger(href="/logout") Logout

        //- Main Content Block
        .container-fluid
          block mda_content

    //- Scripts
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")
    block scripts