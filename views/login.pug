doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Login | NPA Planning Portal
    //- Bootstrap 5 CSS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    style.
      body {
        background-color: #f8f9fa;
        background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
        background-size: 20px 20px;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(12px);
        border-radius: 2rem;
        border: 1px solid #fff;
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.1);
        overflow: hidden;
        width: 100%;
        max-width: 400px;
      }
      .input-group-text {
        background-color: #f8f9fa;
        border-right: none;
        color: #94a3b8;
      }
      .form-control {
        background-color: #f8f9fa;
        border-left: none;
        font-size: 0.95rem;
      }
      .form-control:focus {
        background-color: #fff;
        border-color: #dee2e6;
        box-shadow: none;
      }
      .input-group:focus-within {
        outline: 2px solid #0d6efd;
        border-radius: 0.5rem;
      }
      #loginBtn {
        background: linear-gradient(45deg, #2563eb, #1d4ed8);
        border: none;
        transition: all 0.2s ease;
        letter-spacing: 0.5px;
      }
      #loginBtn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3) !important;
      }
      #loginBtn:active {
        transform: translateY(0);
      }

  body
    .glass-card
      //- Logo & Header Section
      .p-5.pb-4.text-center
        .d-flex.justify-content-center.align-items-center.gap-3.mb-4
          img(src="/images/npa.png" alt="NPA" style="height: 55px; width: auto;")
          .vr(style="height: 40px; width: 1px; background-color: #e2e8f0; opacity: 1;")
          img(src="/images/mubs.png" alt="MUBS" style="height: 55px; width: auto;")
        
        h5.fw-black.text-dark.mb-1.tracking-tight(style="font-weight: 900;") NPA PLANNING PORTAL
        p.text-uppercase.text-muted.mb-0(style="font-size: 0.65rem; letter-spacing: 2px; font-weight: 600;") Secure Access Gateway

      //- Form Section
      .px-5.pb-5
        form#loginForm
          //- Email Field
          .mb-3
            label.form-label.text-uppercase.fw-bold.text-muted(style="font-size: 0.7rem;") Email Address
            .input-group
              span.input-group-text
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                  path(stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206")
              input#email.form-control.py-2(type="email" placeholder="admin@npa.go.ug" required)
          
          //- Password Field
          .mb-4
            label.form-label.text-uppercase.fw-bold.text-muted(style="font-size: 0.7rem;") Password
            .input-group
              span.input-group-text
                svg(xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                  path(stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z")
              input#password.form-control.py-2(type="password" placeholder="••••••••" required)

          //- Cool Action Button
          button#loginBtn.btn.btn-primary.w-100.py-3.rounded-3.fw-bold.shadow-lg(type="button" onclick="handleLogin()")
            .d-flex.align-items-center.justify-content-center.gap-2
              span Sign In
              svg(xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2")
                path(stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6")

      //- Footer Section
      .bg-light.py-3.text-center
        p.mb-0.text-muted.text-uppercase(style="font-size: 9px; letter-spacing: 0.5px; font-weight: 500;")
          | Authorized Access Only • National Planning Authority • 2026

    //- Scripts
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")
    script(src="/js/auth/login.js")