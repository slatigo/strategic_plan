extends ./layout

block npa_content
  .d-flex.justify-content-between.align-items-center.mb-4
    div
      h2.fw-bold Strategic Plan Calls
      p.text-muted Manage the 5-year planning cycles.
    button.btn.btn-primary(onclick="openPlanCallModal()")
      i.fas.fa-bullhorn.me-2
      | Issue New Call

  if calls && calls.length > 0
    .card.border-0.shadow-sm
      .card-body.p-0
        .table-responsive
          table.table.table-hover.align-middle.mb-0
            thead.table-light
              tr
                th.px-4 Plan Cycle (FY)
                th Description
                th Deadline
                th Status
                th.text-end.px-4 Actions
            tbody
              each call in calls
                tr
                  td.px-4.fw-bold= `${call.fy} / ${Number(call.fy) + 5}`
                  td.text-truncate(style="max-width: 250px;")= call.description
                  td
                    - const isOverdue = new Date(call.deadline) < new Date() && call.status === 'Open'
                    span(class=isOverdue ? 'text-danger fw-bold' : '') #{call.deadline}
                  td
                    span.badge.rounded-pill(class=call.status === 'Open' ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary')= call.status
                  td.text-end.px-4
                    button.btn.btn-sm.btn-outline-primary.me-1(onclick=`openPlanCallModal(${JSON.stringify(call)})`)
                      i.fas.fa-edit
                    button.btn.btn-sm.me-1(class=call.status === 'Open' ? 'btn-outline-warning' : 'btn-outline-success' onclick=`toggleCallStatus(${call.id}, '${call.status === 'Open' ? 'Closed' : 'Open'}')`)
                      i.fas(class=call.status === 'Open' ? 'fa-lock' : 'fa-lock-open')
                    button.btn.btn-sm.btn-outline-danger(onclick=`deletePlanCall(${call.id}, '${call.fy}/${call.fy + 5}')`)
                      i.fas.fa-trash-alt
  else
    .text-center.py-5
      h4 No Planning Calls Found.

  // Modal
  .modal.fade#planCallModal(tabindex="-1")
    .modal-dialog
      .modal-content
        .modal-header
          h5.modal-title Issue New Plan Call
          button.btn-close(data-bs-dismiss="modal")
        .modal-body
          form#planCallForm
            .mb-3
              label.form-label.fw-bold Strategic Plan Cycle
              input.form-control(type="text" name="fy" placeholder="e.g. 2025/2030" required)
            .mb-3
              label.form-label.fw-bold Deadline
              input.form-control(type="date" name="deadline" required)
            .mb-3
              label.form-label.fw-bold Description
              textarea.form-control(name="description" rows="3")
        .modal-footer
          button.btn.btn-light(data-bs-dismiss="modal") Cancel
          button.btn.btn-primary(onclick="savePlanCall()") Save Call
block scripts
  //- The '/' at the start refers to the 'public' folder defined in your app.js
  script(src="/js/npa/plan-call-management.js")