extends ./layout

block npa_content
  .d-flex.justify-content-between.align-items-center.mb-4
    div
      h2.fw-bold Strategic Plan Calls
      p.text-muted Manage the windows for MDA planning submissions.
    if calls && calls.length > 0
      button.btn.btn-primary.px-4(onclick="openPlanCallModal()")
        i.fas.fa-bullhorn.me-2
        | Issue New Call

  if calls && calls.length > 0
    .card.border-0.shadow-sm
      .card-body.p-0
        .table-responsive
          table.table.table-hover.align-middle.mb-0
            thead.table-light
              tr
                th.px-4 Fiscal Year
                th Description
                th Deadline
                th Status
                th.text-end.px-4 Actions
            tbody
              each call in calls
                tr
                  td.px-4.fw-bold= call.fy
                  td.text-truncate(style="max-width: 300px;")= call.description
                  td
                    - const isOverdue = new Date(call.deadline) < new Date() && call.status === 'Open'
                    span(class=isOverdue ? 'text-danger fw-bold' : '')
                      i.fas.fa-calendar-day.me-2
                      | #{call.deadline}
                  td
                    span.badge.rounded-pill(class=call.status === 'Open' ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary')= call.status
                  td.text-end.px-4
                    //- Edit Button
                    button.btn.btn-sm.btn-outline-primary(onclick=`openPlanCallModal(${JSON.stringify(call)})` title="Edit")
                      i.fas.fa-edit
                    
                    //- Toggle Status Button
                    button.btn.btn-sm(class=call.status === 'Open' ? 'btn-outline-warning' : 'btn-outline-success' 
                      onclick=`toggleCallStatus(${call.id}, '${call.status === 'Open' ? 'Closed' : 'Open'}')` title=call.status === 'Open' ? 'Close' : 'Open')
                      i.fas(class=call.status === 'Open' ? 'fa-lock' : 'fa-lock-open')

                    //- Delete Button
                    button.btn.btn-sm.btn-outline-danger(onclick=`deletePlanCall(${call.id}, '${call.fy}')` title="Delete")
                      i.fas.fa-trash-alt
                    
  else
    //- Empty State when there are no calls
    .card.border-0.shadow-sm.py-5
      .card-body.text-center
        .mb-4
          i.fas.fa-bullhorn.fa-4x.text-light
        h4.fw-bold No Planning Calls Found
        p.text-muted There are currently no active or past calls for strategic plans.
        button.btn.btn-primary.btn-lg.px-5(onclick="openPlanCallModal()")
          | Issue the First Call

  //- Modal remains the same
  .modal.fade#planCallModal(tabindex="-1")
    .modal-dialog
      .modal-content
        .modal-header
          h5.modal-title Issue New Plan Call
          button.btn-close(type="button" data-bs-dismiss="modal")
        .modal-body
          form#planCallForm
            .mb-3
              label.form-label.fw-bold Fiscal Year
              input.form-control(type="text" name="fy" placeholder="e.g. 2026/2027" required)
            .mb-3
              label.form-label.fw-bold Submission Deadline
              input.form-control(type="date" name="deadline" required)
            .mb-3
              label.form-label.fw-bold Instructions/Description
              textarea.form-control(name="description" rows="3" placeholder="Brief instructions for MDAs...")
        .modal-footer
          button.btn.btn-light(type="button" data-bs-dismiss="modal") Cancel
          button.btn.btn-primary#saveCallBtn(onclick="savePlanCall()") Issue Call

block scripts
  //- Link the external JS file here
  script(src="/js/npa/plan-call-management.js")