extends ./layout

block npa_content
  .container-fluid
    //- Page Header
    .d-flex.justify-content-between.align-items-center.mb-4
      div
        h4.fw-bold.mb-0 Submissions Dashboard
        span.text-muted #{snapshot.quarter} - FY #{snapshot.reportingYear}
      .badge.bg-primary.px-3.py-2 Total MDAs: #{totalItems}

    //- Search & Filter Bar
    .card.border-0.shadow-sm.rounded-4.mb-4
      .card-body.p-3
        form.row.g-2(method="GET")
          .col-md-5
            .input-group
              span.input-group-text.bg-transparent.border-end-0: i.fas.fa-search.text-muted
              input.form-control.border-start-0(type="text" name="search" placeholder="Search by Institution Name..." value=search)
          .col-md-3
            select.form-select(name="status")
              option(value="") All Statuses
              each val in ['Draft', 'Submitted', 'Approved', 'Needs Revision']
                option(value=val selected=statusFilter === val)= val
          .col-md-2.d-grid
            button.btn.btn-primary(type="submit") Filter
          .col-md-2.d-grid
            a.btn.btn-outline-secondary(href=`/npa/report-calls/${snapshot.id}/submissions`) Clear

    //- Submissions Table
    .card.border-0.shadow-sm.rounded-4
      .card-body.p-0
        .table-responsive
          table.table.align-middle.mb-0
            thead.table-light
              tr
                th.px-4.py-3 Institution (MDA)
                th Status
                th Submitted By
                th.text-end.px-4 Action
            tbody
              if mdas && mdas.length > 0
                each mda in mdas
                  - const report = mda.report
                  //- FIX: Convert to string, trim whitespace, and lowercase for a guaranteed match
                  - const rawStatus = report && report.status ? String(report.status).trim().toLowerCase() : 'not started'
                  
                  tr
                    td.px-4
                      .fw-bold.text-dark= mda.name
                      small.text-muted.text-uppercase.ls-wide(style="font-size: 0.7rem;")= mda.code
                    
                    td
                      if rawStatus === 'submitted'
                        span.badge.rounded-pill.bg-warning.text-dark.shadow-sm
                          i.fas.fa-paper-plane.me-1
                          | Submitted
                      else if rawStatus === 'approved'
                        span.badge.rounded-pill.bg-success.shadow-sm
                          i.fas.fa-check-circle.me-1
                          | Approved
                      else if rawStatus === 'needs revision'
                        span.badge.rounded-pill.bg-danger.shadow-sm
                          i.fas.fa-exclamation-triangle.me-1
                          | Revision
                      else if report
                        span.badge.rounded-pill.bg-secondary.shadow-sm
                          i.fas.fa-edit.me-1
                          | Draft
                      else
                        span.text-muted.small 
                          i.fas.fa-minus.me-1
                          | Not Started
                    
                    td
                      if report && report.Reporter
                        .d-flex.align-items-center
                          .avatar-xs.me-2.bg-light.rounded-circle.text-center(style="width:24px; height:24px; line-height:24px;")
                            i.fas.fa-user.text-muted(style="font-size: 0.75rem;")
                          span.small.fw-medium= report.Reporter.name
                      else
                        span.text-muted.small —

                    td.text-end.px-4
                      if report
                        a.btn.btn-sm.btn-primary.px-3.rounded-3(href=`/npa/reports/${report.id}/review`)
                          i.fas.fa-eye.me-1
                          | Review
                      else
                        span.badge.bg-light.text-muted.border.fw-normal No Data
              else
                tr
                  td.text-center.py-5(colspan="4")
                    .py-4
                      i.fas.fa-search.fa-3x.text-light.mb-3
                      h6.text-muted.fw-normal No institutions match your current filters
                      a.btn.btn-sm.btn-link(href="?") Clear all filters

      //- Pagination Footer
      if totalPages > 1
        .card-footer.bg-white.py-3
          nav
            ul.pagination.justify-content-center.mb-0
              li.page-item(class=(currentPage === 1 ? 'disabled' : ''))
                a.page-link(href=`?page=${currentPage - 1}&search=${search}&status=${statusFilter}`) Previous
              
              - for (var i = 1; i <= totalPages; i++)
                li.page-item(class=(i === currentPage ? 'active' : ''))
                  a.page-link(href=`?page=${i}&search=${search}&status=${statusFilter}`)= i
              
              li.page-item(class=(currentPage === totalPages ? 'disabled' : ''))
                a.page-link(href=`?page=${currentPage + 1}&search=${search}&status=${statusFilter}`) Next