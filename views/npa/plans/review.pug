extends ../layout

block npa_content
  - let isLocked = true
  - let isPrintMode = false

  link(href="/stylesheets/plan-editor.css" rel="stylesheet")
  include ../../mda/plans/mixins/_plan_mixins.pug
  
  .container-fluid.py-4
    //- HEADER SECTION
    .d-flex.justify-content-between.align-items-center.mb-4.no-print
      div
        span.badge.bg-dark.mb-2 Submission Review
        h2.mb-0= plan.Mda.name
        p.text-muted Programme: #{plan.Programme ? plan.Programme.programmeName : 'Not Assigned'}
      
      

    //- FULL-WIDTH PLAN CONTENT
    .row
      .col-lg-12
        include ../../partials/_plan_readonly_core.pug

    //- FLOATING ACTION BUTTON (Always present for Reviewers)
    button.btn.btn-primary.shadow-lg.no-print(
      type="button" 
      data-bs-toggle="offcanvas" 
      data-bs-target="#reviewDrawer"
      style="position: fixed; bottom: 30px; right: 30px; z-index: 1060; width: 65px; height: 65px; border-radius: 50%; box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4); display: flex; align-items: center; justify-content: center;"
      title="Open Review Toolbox"
    )
      i.fas.fa-clipboard-check.fa-lg

    //- THE REVIEWER DRAWER (Hidden by default)
    .offcanvas.offcanvas-end#reviewDrawer(tabindex="-1" aria-labelledby="reviewDrawerLabel" style="width: 450px;")
      .offcanvas-header.bg-primary.text-white.shadow-sm
        h5#reviewDrawerLabel.mb-0 
          i.fas.fa-pen-nib.me-2
          | Reviewer Toolbox
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="offcanvas" aria-label="Close")
      
      .offcanvas-body.p-0.d-flex.flex-column
        //- Comment History Area
        .comment-thread.p-4(style="flex: 1; overflow-y: auto; background: #f8f9fa;")
          label.x-small.text-uppercase.fw-bold.text-muted.mb-3 Activity Log
          if plan.Comments && plan.Comments.length > 0
            each comment in plan.Comments
              .card.mb-3.border-0.shadow-sm
                .card-body.p-3
                  .d-flex.justify-content-between.align-items-center.mb-2
                    div
                      i.fas.fa-user-circle.me-1(class=comment.isAdminComment ? 'text-primary' : 'text-success')
                      small.fw-bold(class=comment.isAdminComment ? 'text-primary' : 'text-success')
                        | #{comment.Author ? comment.Author.name : 'System'}
                    small.text-muted(style="font-size: 0.7rem;") #{new Date(comment.createdAt).toLocaleDateString()}
                  p.small.mb-1.text-dark.lh-base= comment.message
                  if comment.statusAtTime
                    .mt-2
                      span.badge.rounded-pill(class=comment.statusAtTime === 'Approved' ? 'bg-success' : 'bg-warning text-dark')
                        | #{comment.statusAtTime}
          else
            .text-center.py-5
              i.fas.fa-comments.fa-2x.text-muted.mb-3
              p.text-muted No remarks yet.

        //- Decision Input Area (Pinned to bottom of drawer)
        if plan.status !== 'Approved'
          .p-4.border-top.bg-white
            label.small.fw-bold.mb-2 Add Remark / Feedback
            textarea#remarks.form-control.mb-3(rows="5" placeholder="Explain your decision or requested changes...")
            
            .d-grid.gap-2
              button.btn.btn-success.btn-lg(onclick="handleDecision('Approved')") 
                i.fas.fa-check-circle.me-2
                | Approve Plan
              button.btn.btn-warning.btn-lg(onclick="handleDecision('Pending Correction')")
                i.fas.fa-exclamation-triangle.me-2
                | Request Revision
        else
          .p-4.text-center.bg-light
            .text-success.mb-2
              i.fas.fa-check-double.fa-3x
            h6.fw-bold.text-success Plan Approved
            p.small.text-muted.mb-0 Locked for implementation.

block scripts
  script.
    window.planConfig = { 
      id: "#{plan.id}", 
      status: "#{plan.status}",
      // Ensure plan.callId exists. If your model uses plan.callId:
      callId: "#{plan.callId}" 
    };
  script(src="/js/npa/review-plan.js")