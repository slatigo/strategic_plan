doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title NPA Portal | #{title}
    //- Bootstrap 5 CSS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    //- Lucide Icons (using the same font set you had)
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
    style.
      body { background-color: #f8f9fa; }
      .sidebar { min-width: 250px; max-width: 250px; min-height: 100vh; transition: all 0.3s; }
      .sidebar .nav-link { color: rgba(255,255,255,.75); padding: 0.8rem 1.5rem; border-radius: 0.5rem; margin: 0 0.5rem 0.2rem; }
      .sidebar .nav-link:hover { color: #fff; background: rgba(255,255,255,.1); }
      .sidebar .nav-link.active { color: #fff; background: #0d6efd; }
      .main-content { width: 100%; }
  
  body
    .d-flex
      //- Sidebar
      aside.sidebar.bg-dark.text-white.d-flex.flex-column
          .p-4.mb-2
            h4.fw-bold.mb-0 NPA ADMIN
          
          nav.nav.flex-column.flex-grow-1
            //- Dashboard
            a.nav-link(href="/npa/dashboard" class=activePage === 'dashboard' ? 'active' : '')
              i.fas.fa-chart-line.me-3
              | Dashboard
            a.nav-link(href="/npa/plan-calls" class=activePage === 'plan-calls' ? 'active' : '')
              i.fas.fa-bullhorn.me-3
              | Plan Calls
            //- NEW: Quarterly Snapshots
            a.nav-link(href="/npa/report-calls" class=activePage === 'report-calls' ? 'active' : '')
              i.fas.fa-calendar-check.me-3
              | Report Calls
            
            //- MDAs
            a.nav-link(href="/npa/mda" class=activePage === 'mdas' ? 'active' : '')
              i.fas.fa-sitemap.me-3
              | MDAs


            //- System Admins
            a.nav-link(href="/npa/admins" class=activePage === 'admins' ? 'active' : '')
              i.fas.fa-user-shield.me-3
              | Admins

            //- Settings
            a.nav-link(href="/npa/settings" class=activePage === 'settings' ? 'active' : '')
              i.fas.fa-gears.me-3
              | Settings

          .p-3.border-top.border-secondary
            button.btn.btn-link.text-danger.text-decoration-none(onclick="handleLogout()")
              i.fas.fa-right-from-bracket.me-2
              | Logout

      //- Main Content
      .main-content.d-flex.flex-column.flex-grow-1
        header.navbar.bg-white.shadow-sm.px-4.py-3.border-bottom
          h5.mb-0.fw-bold.text-dark= title
          .d-flex.align-items-center
            span.me-3.text-muted.small.fw-medium= user.name
            //- Changed justify-center to justify-content-center
            .rounded-circle.bg-primary.text-white.d-flex.align-items-center.justify-content-center.shadow-sm(style="width: 38px; height: 38px; min-width: 38px;")
              span.fw-bold(style="font-size: 0.9rem; line-height: 1;")= user.name.charAt(0).toUpperCase()

        main.p-4
          block npa_content

    //- Bootstrap Bundle with Popper
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")
    script(src="https://unpkg.com/lucide@latest")
    script.
      async function handleLogout() {
          const res = await fetch('/api/logout', { method: 'POST' });
          if(res.ok) window.location.href = '/login';
      }
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")
    block scripts
     