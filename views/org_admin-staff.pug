include org_admin
script(type='text/javascript', src='/javascripts/org_admin_staff.js')
div(class="content")
    div(class="card" id="staff-card")
                div(class="card-header")
                    span Staff
                   
                div(class="card-body")
                    table(class='table')
                        tr

                            td
                                span Select a Unit
                                select(class="form-select" id="dept_id" onchange="dept_id_changed()")
                            td
                                br
                                button(class='btn btn-primary' onclick="get_staff()") <i class='fa fa-view'></i> View Staff
                    br
                    div(id="staff-div-parent" class="hd")
                        button(class="btn btn-primary" onclick="staff_dl()") Add Staff
                        p
                        div(id="staff-div")
div(class="modal" id="staff-modal" data-bs-backdrop="static" data-bs-keyboard="false"  tabindex="-1" )
        div(class="modal-dialog")
            div(class="modal-content")
                div(class="modal-header")
                    h5(class="modal-title") Staff
                    button(type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close")
                div(class="modal-body")
                    
                       
                        div(class="row mb-3")
                            label(class="col-sm-4") Name of Staff
                            div(class="col-sm-8")
                                
                                input(type="text" class="form-control" id="name")
                        div(class="row mb-3")
                            label(class="col-sm-4") Email
                            div(class="col-sm-8")
                               
                                input(type="text" class="form-control" id="email")
                        div(class="row mb-3")
                            label(class="col-sm-4") Designation
                            div(class="col-sm-8")
                               
                                select(class="form-select" id="designation_id")
                                
                div(class="modal-footer")
                       
                        button(class="btn btn-primary" onclick="add_staff()") Submit